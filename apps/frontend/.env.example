# Supabase Auth (required for frontend login)
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
#
# ChatAssistant can talk to either:
# 1. a Supabase Edge Function (`supabase/functions/chat`)
# 2. a dedicated Node backend (`apps/backend`)
#
# Keep the n8n webhook as a server-side secret:
# N8N_CHAT_WEBHOOK_URL=https://n8n.conciergehub.com.br/webhook/chat-assistant
# Optional server-side metadata:
# N8N_CHAT_CHANNEL=web
# N8N_CHAT_SOURCE=concierge-web
#
# Optional dedicated backend URL for authenticated chat routing
# VITE_API_URL=https://api.conciergehub.com.br
# VITE_WS_URL=wss://chat.conciergehub.com.br
