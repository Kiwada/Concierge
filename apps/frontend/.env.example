# Supabase Auth (required for frontend login)
# VITE_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
# VITE_SUPABASE_ANON_KEY=YOUR_SUPABASE_ANON_KEY
#
# Optional frontend public vars (only if backend integration is enabled)
# n8n webhook used by ChatAssistant
# VITE_N8N_CHAT_WEBHOOK_URL=https://n8n.conciergehub.com.br/webhook/chat-assistant
#
# Optional channel metadata sent to n8n payload
# VITE_CHAT_CHANNEL=web
#
# Optional URLs for future integrations
# VITE_API_URL=https://api.conciergehub.com.br
# VITE_WS_URL=wss://chat.conciergehub.com.br
